# Copy to .env and fill in values (do not commit .env)

# Secret key from https://console.anthropic.com/settings/keys (starts with sk-ant-)
# One line only — no quotes, no spaces before/after =. Restart backend after changing.
CLAUDE_API_KEY=

# Optional: default is claude-sonnet-4-20250514; if Anthropic returns 404 model, we retry with CLAUDE_MODEL_FALLBACK (default claude-sonnet-4-5).
# CLAUDE_MODEL=claude-sonnet-4-20250514
# CLAUDE_MODEL_FALLBACK=claude-sonnet-4-5
