# Copy to .env.local to override (gitignored via *.local)
# Or edit .env.development for defaults shared with the team.

# Express origin for Vite dev proxy (default backend PORT is 3001)
VITE_API_PROXY_TARGET=http://127.0.0.1:3001

# API prefix in the browser (proxied in dev; set full URL in production if needed)
VITE_API_BASE=/api
